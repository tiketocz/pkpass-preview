{
  "name": "pkpass-preview",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Workspace root for @tiketo/pkpass-preview. See TIK-119.",
  "license": "MIT",
  "workspaces": ["packages/*"],
  "scripts": {
