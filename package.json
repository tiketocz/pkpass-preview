{
  "name": "pkpass-preview",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Workspace root for @tiketo/pkpass-preview. See TIK-119.",
  "license": "MIT",
  "workspaces": ["packages/*"],
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "NODE_OPTIONS=--max-old-space-size=4096 tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "cd packages/preview && bun run build",
    "storybook": "cd packages/storybook && bun run storybook",
    "storybook:build": "cd packages/storybook && bun run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "happy-dom": "^15.11.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "bun@1.1.38"
}
